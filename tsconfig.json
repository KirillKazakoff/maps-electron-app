{
    "compilerOptions": {
        "target": "ESNext",
        "allowJs": true,
        "jsx": "react-jsx",
        "module": "commonjs",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "outDir": "./dist",
        "rootDir": "./src",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "paths": {
            "*": [
                "node_modules/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "src/filesDebug"
    ]
}